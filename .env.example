# AI provider settings for the AI Twin.
# AI_PROVIDER can be "openai" or "gemini". If omitted, the server auto-picks
# OpenAI when OPENAI_API_KEY exists, otherwise Gemini when GEMINI_API_KEY exists.
AI_PROVIDER="openai"
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4.1-mini"
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.5-flash"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP settings: required for the contact form to send real email.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="username@example.com"
SMTP_PASS="your_smtp_or_app_password"
CONTACT_TO_EMAIL="contact@theafshin.com"
CONTACT_FROM_EMAIL="portfolio@theafshin.com"
